{
  // Relax line length inside code blocks and tables, which routinely contain
  // long bash commands, GraphQL queries, or column-aligned examples that hurt
  // when wrapped. Prose stays at 100 to match the Python line-length in
  // pyproject.toml.
  "MD013": {
    "line_length": 100,
    "code_blocks": false,
    "tables": false
  }
}
